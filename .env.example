# ─── Kafka ───────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ─── AWS Credentials ─────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=ap-south-1

# ─── S3 ──────────────────────────────────────────────
S3_BUCKET_NAME=hospital-patient-vitals-prod

# ─── SNS / SQS ───────────────────────────────────────
SNS_ALERT_TOPIC_ARN=arn:aws:sns:ap-south-1:123456789:patient-critical-alerts
SQS_ALERT_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/123456789/patient-alerts-queue

# ─── Lambda env vars (also set these in AWS Console) ─
DOCTOR_PHONE=+919XXXXXXXXX
DOCTOR_EMAIL=doctor@hospital.com
HOSPITAL_NAME=City Hospital Bhopal

# ─── App ─────────────────────────────────────────────
NUM_PATIENTS=10
VITALS_INTERVAL_SECONDS=1
ALERT_COOLDOWN_SECONDS=60
S3_BATCH_SIZE=100
S3_FLUSH_INTERVAL_SECONDS=30
DASHBOARD_PORT=8000
